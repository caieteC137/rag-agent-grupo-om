# =============================================================
# Dockerfile.backend.prod — PRODUÇÃO
# =============================================================

FROM python:3.12-slim

WORKDIR /app

COPY app/requirements.txt . 
RUN pip install -r requirements.txt

COPY app/ ./app/

RUN useradd -m appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 8000

# PYTHONPATH garante que "from app.config import ..." resolve corretamente
ENV PYTHONPATH=/app

CMD ["adk", "api_server", "app", "--allow_origins=*", "--host=0.0.0.0"]